PORT=10000
HOST=0.0.0.0
DATA_DIR=/var/data
RUNNER_CONFIG_PATH=/app/config/runner.yaml

# OIDC resource server settings. The OAuth browser flow is configured in GPT Actions.
OIDC_ISSUER_URL=https://keycloak.example.com/realms/runner
OIDC_JWKS_URL=https://keycloak.example.com/realms/runner/protocol/openid-connect/certs
OIDC_AUDIENCE=runner-ssh-api
OIDC_REQUIRED_SCOPE=runner:ssh
RUNNER_VIEWER_ROLE=runner.viewer
RUNNER_OPERATOR_ROLE=runner.operator

JOB_CONFIRMATION_TTL_SECONDS=600
MAX_JOB_DURATION_SECONDS=300
MAX_LOG_BYTES=65536
MAX_CONCURRENT_JOBS=2

# Required only for 1Password-backed target credentials.
OP_SERVICE_ACCOUNT_TOKEN=
