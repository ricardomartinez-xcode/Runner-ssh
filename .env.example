PORT=10000
HOST=0.0.0.0
DATA_DIR=/var/data
RUNNER_CONFIG_PATH=/app/config/runner.yaml

# Authentication modes: oidc (default), api_token, dual, or clerk_oauth.
# - oidc: validate signed JWT access tokens locally with issuer/JWKS/audience.
# - api_token: validate only a configured static Bearer token hash.
# - dual: accept either OIDC JWTs or the static Bearer token.
# - clerk_oauth: validate Clerk OAuth access tokens through Clerk token introspection.
AUTH_MODE=oidc

# OIDC resource-server settings. Required when AUTH_MODE=oidc or AUTH_MODE=dual.
OIDC_ISSUER_URL=https://issuer.example.com
OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
OIDC_AUDIENCE=runner-api
OIDC_REQUIRED_SCOPE=runner:ssh
# Comma-separated JWT claim paths used for roles, in addition to Keycloak realm/resource roles.
OIDC_ROLE_CLAIMS=roles,org_role

# Clerk OAuth settings. Required when AUTH_MODE=clerk_oauth.
# Use your Clerk Frontend API URL, for example https://clerk.runner.relead.com.mx.
CLERK_FRONTEND_API_URL=https://clerk.runner.relead.com.mx
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=
CLERK_REQUIRED_SCOPE=email
# Comma-separated token/userinfo fields used as runner roles. "email" is the simplest private GPT setup.
CLERK_ROLE_CLAIMS=email

RUNNER_VIEWER_ROLE=runner.viewer
RUNNER_OPERATOR_ROLE=runner.operator

# Static API Bearer token settings. Required when AUTH_MODE=api_token or AUTH_MODE=dual.
# Keep only the SHA-256 digest in Render; never commit or store the raw token here.
# Generate a raw token: openssl rand -base64 48
# Hash it: printf %s "$TOKEN" | openssl dgst -sha256 -hex | awk '{print $2}'
RUNNER_API_TOKEN_SHA256=
RUNNER_API_TOKEN_ROLES=runner.operator

# GitHub token used by configured Codespace targets.
# Required by config/runner.yaml when a target uses github_token.provider=env and reference=RUNNER_GITHUB_TOKEN.
# Store this only in Render or your secret manager. Do not commit the raw token.
RUNNER_GITHUB_TOKEN=

JOB_CONFIRMATION_TTL_SECONDS=600
MAX_JOB_DURATION_SECONDS=300
MAX_LOG_BYTES=65536
MAX_CONCURRENT_JOBS=2

# Required only for 1Password-backed target credentials.
OP_SERVICE_ACCOUNT_TOKEN=
