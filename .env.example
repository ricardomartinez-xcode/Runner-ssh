PORT=10000
HOST=0.0.0.0
DATA_DIR=/var/data
RUNNER_CONFIG_PATH=/app/config/runner.yaml

APP_NAME="ReLead Ops"
APP_PUBLIC_URL=https://runner.relead.com.mx

# Supabase project settings.
SUPABASE_URL=https://hmhmhpyksqufclqzjkxo.supabase.co
SUPABASE_JWKS_URL=https://hmhmhpyksqufclqzjkxo.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SSH_KEY_ENCRYPTION_SECRET=

# Authentication modes: oidc (default), api_token, dual, or clerk_oauth.
# For the new ReLead Ops admin UI, prefer Supabase Auth.
# The current runner API can keep OIDC/api_token during migration.
AUTH_MODE=oidc

# OIDC resource-server settings. Required when AUTH_MODE=oidc or AUTH_MODE=dual.
# ReLead Ops can derive these from SUPABASE_URL/SUPABASE_JWKS_URL.
OIDC_ISSUER_URL=https://hmhmhpyksqufclqzjkxo.supabase.co/auth/v1
OIDC_JWKS_URL=https://hmhmhpyksqufclqzjkxo.supabase.co/auth/v1/.well-known/jwks.json
OIDC_AUDIENCE=authenticated
# Leave blank for plain Supabase Auth access tokens unless you issue a custom scope claim.
OIDC_REQUIRED_SCOPE=
OIDC_ROLE_CLAIMS=app_metadata.roles,app_metadata.role,roles,org_role

# Clerk OAuth settings. Deprecated for ReLead Ops. Keep only during migration if needed.
CLERK_FRONTEND_API_URL=https://clerk.runner.relead.com.mx
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=
CLERK_REQUIRED_SCOPE=email
CLERK_ROLE_CLAIMS=email

RUNNER_VIEWER_ROLE=runner.viewer
RUNNER_OPERATOR_ROLE=runner.operator

# Static API Bearer token settings. Required when AUTH_MODE=api_token or AUTH_MODE=dual.
# Keep only the SHA-256 digest in Render; never commit or store the raw token here.
# Generate a raw token: openssl rand -base64 48
# Hash it: printf %s "$TOKEN" | openssl dgst -sha256 -hex | awk '{print $2}'
RUNNER_API_TOKEN_SHA256=
RUNNER_API_TOKEN_ROLES=runner.operator

# Optional Render variable for a ReleadServer target that uses key plus password.
# Value must be JSON with private_key and password. Do not commit the raw value.
RELEADSERVER_SSH_CREDENTIAL=

# Required in Render when a cloudflare_tunnel target is protected by Cloudflare Access.
TUNNEL_SERVICE_TOKEN_ID=
TUNNEL_SERVICE_TOKEN_SECRET=

# Required only on the target host when installing the named Cloudflare Tunnel service.
CLOUDFLARE_TUNNEL_TOKEN=

# Break-glass recovery console at /bash. Keep disabled until Cloudflare Access,
# the dedicated Render SSH key, and the recovery key digest are configured.
BREAK_GLASS_ENABLED=false
BREAK_GLASS_REQUIRE_CLOUDFLARE_ACCESS=true
BREAK_GLASS_KEY_SHA256=
BREAK_GLASS_SESSION_SECRET=
BREAK_GLASS_SESSION_TTL_SECONDS=600
BREAK_GLASS_MAX_SESSION_BYTES=16777216
BREAK_GLASS_MAX_FAILED_ATTEMPTS=5
BREAK_GLASS_LOCKOUT_SECONDS=900
BREAK_GLASS_RENDER_PRIVATE_KEY=
BREAK_GLASS_RENDER_SERVICE_ID=
BREAK_GLASS_RENDER_SSH_HOST=
BREAK_GLASS_RENDER_KNOWN_HOSTS=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=

JOB_CONFIRMATION_TTL_SECONDS=600
MAX_JOB_DURATION_SECONDS=300
MAX_LOG_BYTES=65536
MAX_CONCURRENT_JOBS=2

# Required only for 1Password-backed target credentials.
OP_SERVICE_ACCOUNT_TOKEN=
